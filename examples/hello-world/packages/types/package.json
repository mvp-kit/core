{
  "name": "@repo/types",
  "version": "0.0.1",
  "private": true,
  "description": "hello-world - types",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@trpc/server": "11.7.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./types/*": "./dist/types/*.js",
    "./schemas/*": "./dist/schemas/*.js",
    "./router": "./dist/router.js",
    "./frontend": "./dist/frontend.js"
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "types/*": [
        "./dist/types/*"
      ],
      "schemas/*": [
        "./dist/schemas/*"
      ],
      "router": [
        "./dist/router.d.ts"
      ],
      "frontend": [
        "./dist/frontend.d.ts"
      ]
    }
  }
}
