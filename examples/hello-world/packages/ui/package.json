{
  "name": "@repo/ui",
  "version": "0.0.1",
  "private": true,
  "description": "hello-world - ui",
  "type": "module",
  "types": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./components/*": "./src/components/*.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./components/layout/*": "./src/components/layout/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./styles.css": "./src/styles.css"
  },
  "sideEffects": [
    "*.css",
    "./src/styles.css"
  ],
  "files": [
    "src",
    "components.json"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc --watch",
    "dev:watch": "tsc --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.3.1",
    "tsc-alias": "1.8.17",
    "typescript": "6.0.3"
  }
}
