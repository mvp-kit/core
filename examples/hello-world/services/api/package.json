{
  "name": "@repo/api",
  "version": "0.0.1",
  "private": true,
  "description": "hello-world - backend",
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "wrangler d1 migrations apply hello-world-db --env production --remote || echo 'No migrations to apply' && wrangler deploy --env production",
    "dev": "wrangler dev --port 3011",
    "preview": "wrangler dev --port 3011",
    "setup:remote": "bash setup-remote.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .wrangler dist",
    "db:init": "mkdir -p .wrangler/state/v3/d1/miniflare-D1DatabaseObject && echo 'Local D1 database initialized'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply hello-world-db --env production --remote",
    "db:migrate:local": "wrangler d1 migrations apply hello-world-db-dev --local",
    "db:execute:local": "wrangler d1 execute hello-world-db-dev --local",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/trpc-server": "0.4.2",
    "@trpc/server": "11.18.0",
    "better-auth": "1.6.20",
    "better-auth-cloudflare": "0.3.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.26",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260621.1",
    "@types/node": "26.0.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "wrangler": "4.103.0"
  }
}
