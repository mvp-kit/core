{
  "name": "@repo/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Marketing website for hello-world",
  "config": {
    "cloudflarePagesProject": "hello-world-web"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev": "vite dev",
    "preview": "wrangler pages dev dist --port 3001",
    "deploy": "vite build && wrangler pages deploy dist --project-name \"$npm_package_config_cloudflarePagesProject\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mvp-kit/vite-sitemap-plugin": "0.1.0",
    "@repo/api": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@trpc/client": "11.18.0",
    "@trpc/react-query": "11.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260621.1",
    "@mdx-js/rollup": "3.1.1",
    "@tanstack/router-plugin": "1.168.18",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wrangler": "4.103.0"
  }
}
